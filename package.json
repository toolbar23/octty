{
  "name": "octty",
  "version": "0.1.0",
  "private": true,
  "main": "build/electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "node scripts/build-electron.mjs && electron build/electron/main.js",
    "dev:terminal-debug": "OCTTY_DEBUG_TERMINAL=1 node scripts/build-electron.mjs && electron build/electron/main.js",
    "dev:profile": "OCTTY_OPEN_DEVTOOLS=1 node scripts/build-electron.mjs && electron build/electron/main.js",
    "start": "electron build/electron/main.js",
    "build": "node scripts/build-electron.mjs",
    "pack:linux": "npm run build && NODE_NO_WARNINGS=1 node node_modules/electron-builder/install-app-deps.js && NODE_NO_WARNINGS=1 node node_modules/electron-builder/cli.js --linux dir",
    "dist": "npm run dist:linux",
    "dist:linux": "npm run build && NODE_NO_WARNINGS=1 node node_modules/electron-builder/install-app-deps.js && NODE_NO_WARNINGS=1 node node_modules/electron-builder/cli.js --linux AppImage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "ghostty-web": "^0.4.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "electron": "^37.3.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.10",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "npm@11.6.0",
  "build": {
    "appId": "dev.octty.app",
    "productName": "Octty",
    "beforeBuild": "./scripts/electron-builder-before-build.cjs",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/electron/**/*"
    ],
    "extraResources": [
      {
        "from": "build/electron/runtime",
        "to": "runtime"
      },
      {
        "from": "node_modules/node-pty",
        "to": "node_modules/node-pty"
      },
      {
        "from": "node_modules/node-addon-api",
        "to": "node_modules/node-addon-api"
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    }
  }
}
